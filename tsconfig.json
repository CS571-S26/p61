{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"lib": [
			"ES2022",
			"DOM"
		],
		"jsx": "react-jsx",
		"sourceMap": true,
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true
	},
	"include": [
		"apps/**/*.ts",
		"apps/**/*.tsx",
		"packages/**/*.ts",
		"packages/**/*.tsx",
		"src/**/*.ts",
		"test-fixtures/**/*.ts"
	],
	"exclude": [
		"node_modules",
		"out",
		"dist",
		"playwright.config.ts",
		"apps/website"
	]
}
